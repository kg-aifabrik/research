se,"boundElements":null,"updated":1,"link":null,"locked":false,"id":"e125","type":"text","x":40,"y":800,"width":959.14,"height":32.5,"roundness":null,"text":"Spectrum stops at L4 — the client TLS session rides through to the pod untouched. Inside the DC the path is exactly the\nMetalLB / Cilium BGP picture; the only addition is the border DNAT from the public IP to the Service VIP.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Spectrum stops at L4 — the client TLS session rides through to the pod untouched. Inside the DC the path is exactly the\nMetalLB / Cilium BGP picture; the only addition is the border DNAT from the public IP to the Service VIP.","lineHeight":1.25},{"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"seed":128,"version":1,"versionNonce":128,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"id":"e127","type":"text","x":40,"y":852,"width":989.52,"height":30,"roundness":null,"text":"One Spectrum app + one public IP:port per exposed Service. Pod sees Cloudflare edge IPs as source unless Proxy Protocol is\nenabled and consumed by an LB in front. Spectrum = Enterprise; plain-HTTPS workloads can use the standard CF proxy or Tunnel instead.","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"One Spectrum app + one public IP:port per exposed Service. Pod sees Cloudflare edge IPs as source unless Proxy Protocol is\nenabled and consumed by an LB in front. Spectrum = Enterprise; plain-HTTPS workloads can use the standard CF proxy or Tunnel instead.","lineHeight":1.25}],"appState":{"viewBackgroundColor":"#ffffff","gridSize":null},"files":{}}
