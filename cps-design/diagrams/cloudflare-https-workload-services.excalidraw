d":1,"link":null,"locked":false,"id":"e139","type":"text","x":820,"y":760,"width":334.18,"height":27.5,"roundness":null,"text":"CiliumBGPClusterConfig + CiliumLoadBalancerIPPool\nCRDs define the BGP peers and the VIP pool","fontSize":11,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CiliumBGPClusterConfig + CiliumLoadBalancerIPPool\nCRDs define the BGP peers and the VIP pool","lineHeight":1.25},{"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"seed":142,"version":1,"versionNonce":142,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"id":"e141","type":"text","x":40,"y":890,"width":983.3199999999999,"height":32.5,"roundness":null,"text":"Both sites present the same contract to Cloudflare: an HTTPS origin at the Service VIP. Choosing MetalLB vs Cilium changes\nonly the in-node machinery — the Cloudflare path and the fabric eBGP/ECMP are identical.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Both sites present the same contract to Cloudflare: an HTTPS origin at the Service VIP. Choosing MetalLB vs Cilium changes\nonly the in-node machinery — the Cloudflare path and the fabric eBGP/ECMP are identical.","lineHeight":1.25},{"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"seed":144,"version":1,"versionNonce":144,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"id":"e143","type":"text","x":40,"y":942,"width":915.12,"height":30,"roundness":null,"text":"TLS re-terminates at the edge, so pods see Cloudflare as the TCP client; the real client IP arrives in the CF-Connecting-IP\nHTTP header — externalTrafficPolicy / DSR concerns mostly drop away for HTTPS workloads.","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"TLS re-terminates at the edge, so pods see Cloudflare as the TCP client; the real client IP arrives in the CF-Connecting-IP\nHTTP header — externalTrafficPolicy / DSR concerns mostly drop away for HTTPS workloads.","lineHeight":1.25}],"appState":{"viewBackgroundColor":"#ffffff","gridSize":null},"files":{}}
