,"id":"e105","type":"text","x":40,"y":960,"width":1104.22,"height":32.5,"roundness":null,"text":"Both options land on the same HA endpoint (the control-plane VIP). Tunnel: client-side agent, zero inbound, identity checked at the edge.\nSpectrum: zero client setup, but an inbound allowlist, an Enterprise plan, and no edge identity gate.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Both options land on the same HA endpoint (the control-plane VIP). Tunnel: client-side agent, zero inbound, identity checked at the edge.\nSpectrum: zero client setup, but an inbound allowlist, an Enterprise plan, and no edge identity gate.","lineHeight":1.25},{"angle":0,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"seed":108,"version":1,"versionNonce":108,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"id":"e107","type":"text","x":40,"y":1015,"width":885.36,"height":15,"roundness":null,"text":"In both paths Cloudflare never decrypts the kubectl session — client-certificate mTLS runs end-to-end to the apiserver.","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"In both paths Cloudflare never decrypts the kubectl session — client-certificate mTLS runs end-to-end to the apiserver.","lineHeight":1.25}],"appState":{"viewBackgroundColor":"#ffffff","gridSize":null},"files":{}}
