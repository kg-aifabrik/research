   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300071,
   "versionNonce": 300071,
   "text": "\u2465 node2 eBPF: 10.244.2.7 is a local pod \u2192 bpf_redirect into podB netns. Delivered. (Return path symmetric.)",
