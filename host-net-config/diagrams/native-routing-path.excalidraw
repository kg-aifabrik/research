   "type": "text",
   "x": 75,
   "y": 524,
   "width": 553,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300066,
   "versionNonce": 300066,
   "text": "\u2460 podA emits  src 10.244.1.5 \u2192 dst 10.244.2.7.  Plain packet, no encap.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2460 podA emits  src 10.244.1.5 \u2192 dst 10.244.2.7.  Plain packet, no encap.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300067",
   "type": "text",
   "x": 75,
   "y": 552,
   "width": 1263,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300067,
   "versionNonce": 300067,
   "text": "\u2461 node1 eBPF: dst not local \u2192 consult tenant routing table \u2192 next-hop leaf gateway 10.40.0.254 on bond0.400. Host does NOT encapsulate; packet egresses unchanged.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2461 node1 eBPF: dst not local \u2192 consult tenant routing table \u2192 next-hop leaf gateway 10.40.0.254 on bond0.400. Host does NOT encapsulate; packet egresses unchanged.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300068",
   "type": "text",
   "x": 75,
   "y": 580,
   "width": 1232,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300068,
   "versionNonce": 300068,
   "text": "\u2462 leaf-1: port+VLAN400 \u2192 tenant-A VRF. Has 10.244.2.0/24 via EVPN type-5 from leaf-9. Encapsulates in VXLAN with tenant-A L3VNI (leaf ASIC, hidden from host).",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2462 leaf-1: port+VLAN400 \u2192 tenant-A VRF. Has 10.244.2.0/24 via EVPN type-5 from leaf-9. Encapsulates in VXLAN with tenant-A L3VNI (leaf ASIC, hidden from host).",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300069",
   "type": "text",
   "x": 75,
   "y": 608,
   "width": 819,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300069,
   "versionNonce": 300069,
   "text": "\u2463 spine: forwards on OUTER header only (leaf-1 VTEP \u2192 leaf-9 VTEP). Never sees pod IPs or the tenant VRF.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2463 spine: forwards on OUTER header only (leaf-1 VTEP \u2192 leaf-9 VTEP). Never sees pod IPs or the tenant VRF.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
