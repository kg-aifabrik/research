   "id": "t300070",
   "type": "text",
   "x": 75,
   "y": 636,
   "width": 990,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300070,
   "versionNonce": 300070,
   "text": "\u2464 leaf-9: decap VXLAN \u2192 L3VNI maps to tenant-A VRF \u2192 routes 10.244.2.7 to connected subnet \u2192 out its port+VLAN400 toward node2.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2464 leaf-9: decap VXLAN \u2192 L3VNI maps to tenant-A VRF \u2192 routes 10.244.2.7 to connected subnet \u2192 out its port+VLAN400 toward node2.",
   "lineHeight": 1.25,
   "baseline": 11
  },
