   "seed": 300053,
   "versionNonce": 300053,
   "text": "\u2022 Every host emits the SAME VLAN IDs (100/200/300/400 + RoCE). No per-tenant host config \u2014 a node is tenant-agnostic until the leaf binds its ports.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
