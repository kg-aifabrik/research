   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300054",
   "type": "text",
   "x": 95,
   "y": 747,
   "width": 1138,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300054,
   "versionNonce": 300054,
   "text": "\u2022 VLAN 100 (host-vrf) carries ONLY provider traffic: PXE, kubelet\u2194vcluster API, telemetry, patching. Default route lives here. No tenant pod data.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2022 VLAN 100 (host-vrf) carries ONLY provider traffic: PXE, kubelet\u2194vcluster API, telemetry, patching. Default route lives here. No tenant pod data.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300055",
   "type": "text",
   "x": 95,
   "y": 770,
   "width": 1123,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300055,
   "versionNonce": 300055,
   "text": "\u2022 VLAN 300/400 + RoCE land in the tenant VRF. Native routing: pod CIDRs are advertised by Cilium BGP into that VRF \u2014 no host-side overlay encap.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2022 VLAN 300/400 + RoCE land in the tenant VRF. Native routing: pod CIDRs are advertised by Cilium BGP into that VRF \u2014 no host-side overlay encap.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300056",
   "type": "text",
   "x": 95,
   "y": 793,
   "width": 1294,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300056,
   "versionNonce": 300056,
   "text": "\u2022 Host is multi-VRF: presence in host-vrf (.100) AND its tenant VRF (.300/.400/RoCE). Policy/source routing keeps kubelet on the host table, pods on the tenant table.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2022 Host is multi-VRF: presence in host-vrf (.100) AND its tenant VRF (.300/.400/RoCE). Policy/source routing keeps kubelet on the host table, pods on the tenant table.",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
   "angle": 0,
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1700000000000,
   "link": null,
   "locked": false,
   "id": "t300057",
   "type": "text",
   "x": 95,
   "y": 816,
   "width": 990,
   "height": 16,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "roundness": null,
   "seed": 300057,
   "versionNonce": 300057,
   "text": "\u2022 Reassigning a node to another tenant = rebind {port,VLAN}\u2192VNI at the leaf + scrub/reimage. Zero change to the host's Netplan.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2022 Reassigning a node to another tenant = rebind {port,VLAN}\u2192VNI at the leaf + scrub/reimage. Zero change to the host's Netplan.",
   "lineHeight": 1.25,
   "baseline": 11
  }
